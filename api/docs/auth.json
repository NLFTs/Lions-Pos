{
  "module": "Authentication",
  "base_path": "/api/v1/auth",
  "order": 1,
  "endpoints": [
    {
      "method": "POST",
      "path": "/login",
      "description": "Authenticate user and receive JWT tokens",
      "request_body": {
        "username": "admin",
        "password": "password123"
      },
      "response_sample": {
        "status": 200,
        "message": "Success",
        "data": {
          "access_token": "eyJhbG...",
          "refresh_token": "def456..."
        }
      }
    },
    {
      "method": "GET",
      "path": "/me",
      "description": "Get current authenticated user profile",
      "headers": {
        "Authorization": "Bearer <access_token>"
      },
      "response_sample": {
        "status": 200,
        "message": "Success",
        "data": {
          "id": 1,
          "username": "admin",
          "fullname": "Administrator",
          "roles": ["admin"],
          "permissions": [
            "product.index",
            "product.store",
            "purchase_order.index",
            "purchase_order.store"
          ]
        }
      }
    },
    {
      "method": "POST",
      "path": "/refresh",
      "description": "Refresh access token using refresh token",
      "query_params": {
        "refreshToken": "string"
      }
    },
    {
      "method": "POST",
      "path": "/logout",
      "description": "Invalidate current session",
      "query_params": {
        "refreshToken": "string"
      }
    }
  ]
}
