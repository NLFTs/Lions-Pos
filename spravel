#!/bin/bash
# Spravel CLI вЂ” Shortcut commands for development
# Usage: ./spravel <command>
#
# Frontend:
#   frontend:install   вЂ” Install frontend dependencies (pnpm)
#   frontend:build     вЂ” Build Vue.js в†’ src/main/resources/static
#   frontend:dev       вЂ” Start Vite dev server (hot-reload)
#   frontend:clean     вЂ” Clean frontend build output
#
# Backend:
#   backend:dev        вЂ” Run Spring Boot dev server (skip frontend build)
#   backend:build      вЂ” Compile backend only (skip frontend & tests)
#   backend:test       вЂ” Run backend tests
#   backend:clean      вЂ” Clean backend build output
#
# Fullstack:
#   full:build         вЂ” Build frontend + backend JAR (production)
#   full:clean         вЂ” Clean everything (frontend + backend)
#   full:dev           вЂ” Start both Vite + Spring Boot (parallel)
#
set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
MVNW="$DIR/mvnw"
FRONTEND="$DIR/frontend"
PNPM="npx -y pnpm"

case "$1" in
  # в”Ђв”Ђ Frontend в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  frontend:install)
    echo "рџ“¦ Installing frontend dependencies..."
    cd "$FRONTEND" && $PNPM install --frozen-lockfile
    ;;
  frontend:build)
    echo "рџ”Ё Building frontend..."
    cd "$FRONTEND" && $PNPM install --frozen-lockfile && $PNPM run build
    ;;
  frontend:dev)
    echo "вљЎ Starting Vite dev server..."
    cd "$FRONTEND" && $PNPM run dev
    ;;
  frontend:clean)
    echo "рџ§№ Cleaning frontend build output..."
    rm -rf "$DIR/src/main/resources/static/assets" "$DIR/src/main/resources/static/index.html"
    echo "Done."
    ;;

  # в”Ђв”Ђ Backend в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  backend:dev)
    echo "рџљЂ Starting Spring Boot (skip frontend build)..."
    "$MVNW" spring-boot:run -Dexec.skip=true
    ;;
  backend:build)
    echo "рџ”Ё Compiling backend..."
    "$MVNW" compile -Dexec.skip=true -q
    ;;
  backend:test)
    echo "рџ§Є Running backend tests..."
    "$MVNW" test -Dexec.skip=true
    ;;
  backend:clean)
    echo "рџ§№ Cleaning backend build..."
    "$MVNW" clean -q
    ;;

  # в”Ђв”Ђ Fullstack в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  full:build)
    echo "рџ“¦ Building frontend + backend JAR..."
    "$MVNW" package -DskipTests
    ;;
  full:clean)
    echo "рџ§№ Cleaning everything..."
    rm -rf "$DIR/src/main/resources/static/assets" "$DIR/src/main/resources/static/index.html"
    "$MVNW" clean -q
    echo "Done."
    ;;
  full:dev)
    clear
    cat <<'EOF'
[31m
        .d$b.
       i$$A$$L  .d$b
     .$$F` `$$L.$$A$$.
    j$$'    `4$$:` `$$.
   j$$'     .4$:    `$$.
  j$$`     .$$:      `4$L
 :$$:____.d$$:  _____.:$$:
 `4$$$$$$$$P` .i$$$$$$$$P`
[0m
EOF
    echo ""

    # в”Ђв”Ђ Ambil Network IP в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    # Coba berbagai cara, prioritas: ip route в†’ hostname -I в†’ ipconfig (Windows)
    NETWORK_IP=$(ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}')
    if [ -z "$NETWORK_IP" ]; then
      NETWORK_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
    fi
    if [ -z "$NETWORK_IP" ]; then
      NETWORK_IP=$(ipconfig 2>/dev/null | grep -i "IPv4" | grep -v "127.0.0.1" | head -1 | awk -F': ' '{print $2}' | tr -d '[:space:]')
    fi
    if [ -z "$NETWORK_IP" ]; then
      NETWORK_IP="localhost"
    fi

    # в”Ђв”Ђ Ambil port Vite dari .env.development в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    VITE_PORT=$(grep -E '^VITE_DEV_PORT=' "$FRONTEND/.env.development" 2>/dev/null | cut -d= -f2 | tr -d '[:space:]')
    VITE_PORT=${VITE_PORT:-5173}

    # в”Ђв”Ђ Ambil DB host dari application.properties в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    RAW_DB=$(grep -E '^spring\.datasource\.url=' "$DIR/src/main/resources/application.properties" 2>/dev/null | cut -d= -f2-)
    if echo "$RAW_DB" | grep -q 'SPRING_DATASOURCE_URL'; then
      DB_URL="${SPRING_DATASOURCE_URL:-localhost:5433}"
      DB_URL=$(echo "$DB_URL" | sed 's|jdbc:postgresql://||' | cut -d/ -f1)
    else
      DB_URL=$(echo "$RAW_DB" | sed 's|.*jdbc:postgresql://||' | cut -d/ -f1)
    fi
    DB_URL=${DB_URL:-localhost:5433}

    # в”Ђв”Ђ Tampilkan Banner в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "\e[32m  в–І Spravel 2.1.0 (TwinTurbo)\e[0m"
    echo ""
    echo -e "  - Local:         \e[36mhttp://localhost:${VITE_PORT}\e[0m"
    echo -e "  - Network:       \e[36mhttp://${NETWORK_IP}:${VITE_PORT}\e[0m"
    echo -e "  - Environments:  \e[33m.env\e[0m"
    echo -e "  - DB_Network:    \e[33m${DB_URL}\e[0m"
    echo ""
    echo -e "\e[32m  вњ“ Starting...\e[0m"
    echo ""

    trap 'kill 0' EXIT

    # в”Ђв”Ђ Jalankan Vite dulu, suppress output default Vite в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    (cd "$FRONTEND" && $PNPM run dev 2>&1 | grep -vE "^\s*$|VITE v[0-9]|Local:|Network:|ready in|press h|вћњ") &
    VITE_PID=$!

    # Tunggu Vite siap sebelum Spring Boot
    sleep 3

    # в”Ђв”Ђ Jalankan Spring Boot, filter log awal в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    # Tampilkan mulai dari InitializeUserDetailsManagerConfigurer ke bawah
    # Error/Exception selalu ditampilkan meskipun belum sampai titik itu
    "$MVNW" spring-boot:run -Dexec.skip=true 2>&1 | awk '
      /InitializeUserDetailsManagerConfigurer/ { started=1 }
      /ERROR|Exception in thread|BUILD FAILURE/ { started=1 }
      started {
        if (/ERROR|Exception|BUILD FAILURE/) {
          print "\033[31m" $0 "\033[0m"
        } else if (/ WARN /) {
          print "\033[33m" $0 "\033[0m"
        } else if (/ DEBUG /) {
          print "\033[90m" $0 "\033[0m"
        } else {
          print $0
        }
      }
    '
    ;;

  # в”Ђв”Ђ Help в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  *)
    echo ""
    echo "  Spravel CLI вЂ” Usage: ./spravel <command>"
    echo ""
    echo "  Frontend:"
    echo "    frontend:install   Install dependencies (pnpm)"
    echo "    frontend:build     Build Vue в†’ static/"
    echo "    frontend:dev       Vite dev server (HMR)"
    echo "    frontend:clean     Clean build output"
    echo ""
    echo "  Backend:"
    echo "    backend:dev        Spring Boot dev server"
    echo "    backend:build      Compile backend only"
    echo "    backend:test       Run tests"
    echo "    backend:clean      Clean build"
    echo ""
    echo "  Fullstack:"
    echo "    full:build         Frontend + backend JAR"
    echo "    full:clean         Clean everything"
    echo "    full:dev           Vite + Spring Boot (parallel)"
    echo ""
    ;;
esac
