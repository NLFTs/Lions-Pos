# ==============================================================================
# Spravel Frontend — Environment Variables (Template)
# ==============================================================================
# Copy ke .env.local dan sesuaikan. JANGAN commit .env.local.
# ==============================================================================

# Backend API URL (untuk production build)
VITE_API_URL=http://localhost:8090

# Vite dev server port (default: 5173)
VITE_DEV_PORT=5173

# App title di browser tab
VITE_APP_TITLE=Spravel
